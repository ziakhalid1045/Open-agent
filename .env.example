# Open Agents Configuration
# Copy this file to .env and fill in your values
# All settings use the OPEN_AGENTS_ prefix

# Security (generate with: openssl rand -hex 32)
OPEN_AGENTS_SECRET_KEY=change-me-in-production

# AI Provider: "groq", "openai", or "ollama"
OPEN_AGENTS_AI_PROVIDER=groq
OPEN_AGENTS_AI_MODEL=llama-3.3-70b-versatile

# Groq API Key (required if AI_PROVIDER=groq) — free at https://console.groq.com
OPEN_AGENTS_GROQ_API_KEY=

# OpenAI API Key (required if AI_PROVIDER=openai)
OPEN_AGENTS_OPENAI_API_KEY=

# Ollama URL (required if AI_PROVIDER=ollama)
OPEN_AGENTS_OLLAMA_BASE_URL=http://localhost:11434

# Database
OPEN_AGENTS_DATABASE_URL=sqlite+aiosqlite:///./open_agents.db

# Workspace
OPEN_AGENTS_WORKSPACE_ROOT=./workspaces

# Browser
OPEN_AGENTS_HEADLESS=true

# Encryption key for user data (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
OPEN_AGENTS_ENCRYPTION_KEY=
