# Open Agents Configuration
# Copy this file to .env and fill in your values

# Security (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production

# AI Provider: "openai" or "ollama"
AI_PROVIDER=openai
AI_MODEL=gpt-4o

# OpenAI API Key (required if AI_PROVIDER=openai)
OPENAI_API_KEY=

# Ollama URL (required if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Database
DATABASE_URL=sqlite+aiosqlite:///./open_agents.db

# Workspace
WORKSPACE_ROOT=./workspaces

# Browser
OPEN_AGENTS_HEADLESS=true

# Encryption key for user data (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=
