<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EShort" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>

    <style name="Theme.EShort.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF000000</item>
        <item name="postSplashScreenTheme">@style/Theme.EShort</item>
    </style>
</resources>
