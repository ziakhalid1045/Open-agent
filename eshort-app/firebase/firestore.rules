rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Videos collection
    match /videos/{videoId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.authorId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin() || resource.data.authorId == request.auth.uid;
    }

    // Comments collection
    match /comments/{commentId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.authorId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.authorId == request.auth.uid;
    }

    // Conversations collection
    match /conversations/{convoId} {
      allow read: if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid in resource.data.members;

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth();
      }
    }

    // Notifications collection
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid;
    }

    // Reports collection
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    // Broadcasts collection
    match /broadcasts/{broadcastId} {
      allow read: if isAuth();
      allow create: if isAdmin();
    }
  }
}
